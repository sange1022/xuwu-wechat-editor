{
  "name": "wechat-flipped-editor",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:win": "npm run build && electron-builder --win nsis --x64",
    "test": "vitest run",
    "preview": "vite preview --host 0.0.0.0"
  },
  "build": {
    "appId": "com.xuwu.wechat.editor",
    "productName": "戌無公众号排版工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "戌無公众号排版工具",
      "artifactName": "戌無公众号排版工具-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.468.0",
    "marked": "^12.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.4"
  }
}
